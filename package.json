{
  "name": "horizon-drupal-client",
  "version": "0.1.0",
  "description": "Type-safe TypeScript client for Horizon Drupal. Full autocomplete, zero GraphQL required.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen/generate.d.ts",
      "import": "./dist/codegen/generate.js",
      "require": "./dist/codegen/generate.js"
    }
  },
  "bin": {
    "horizon-schema": "./bin/schema-sync.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "horizon",
    "drupal",
    "headless",
    "cms",
    "typescript",
    "graphql",
    "client",
    "type-safe",
    "codegen"
  ],
  "author": "MMGY Horizon",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@types/node": "^20.10.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "bin/"
  ]
}
